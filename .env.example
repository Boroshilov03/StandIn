# StandIn backend environment variables.
# Copy to .env and fill in real values. Never commit .env.

# --- Cloud LLM ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- ASI:One / Agentverse ---
ASI_ONE_API_KEY=

# --- MongoDB (history, deltas, action approvals) ---
MONGODB_URI=

# --- uAgents seeds (deterministic addresses) ---
ORCHESTRATOR_SEED=
STATUS_AGENT_SEED=
HISTORICAL_AGENT_SEED=
PERFORM_ACTION_SEED=
WATCHDOG_AGENT_SEED=

# --- Slack (read + write) ---
SLACK_BOT_TOKEN=
SLACK_USER_TOKEN=

# --- ASUS GX10 edge trust layer ---
# Service runs on the GX10 device on the LAN. status_agent calls it before
# sending raw workplace data to Gemini.
GX10_BASE_URL=http://gx10-5493:8001
GX10_ENABLED=true
GX10_TIMEOUT_SECONDS=60
